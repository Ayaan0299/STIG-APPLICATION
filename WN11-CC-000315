<#
.SYNOPSIS
    This PowerShell script disables the 'Always install with elevated privileges' Windows Installer policy.
.NOTES
    Author          : Mohammad Ayaan Latif
    LinkedIn        : linkedin.com/in/ayaan-latif-588540350/
    Date Created    : 2026-06-14
    Last Modified   : 2026-06-14
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-CC-000315
    Documentation   : https://stigaview.com/products/win11/v2r7/WN11-CC-000315/
.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 
.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\__remediation_template(STIG-ID-WN11-CC-000315).ps1 
#>

New-Item -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer" -Force
New-Item -Path "HKCU:\SOFTWARE\Policies\Microsoft\Windows\Installer" -Force

Set-ItemProperty -Path "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Installer" -Name "AlwaysInstallElevated" -Value 0 -Type DWord -Force
Set-ItemProperty -Path "HKCU:\SOFTWARE\Policies\Microsoft\Windows\Installer" -Name "AlwaysInstallElevated" -Value 0 -Type DWord -Force
